{
  "variables": {
    "applicationId": "e9fdb985-9173-4e01-9d73-ac2d60d1dc8e",
    "apiKey": "this_really_should_be_a_long_random_alphanumeric_value_but_this_still_works",
    "asymmetricKeyId": "#{UUID()}",
    "defaultTenantId": "d7d09513-a3f5-401c-9685-34ab6c552453",
    "adminEmail": "admin@digitalsouschef.local",
    "adminPassword": "password",
    "userEmail": "chef@example.com",
    "userPassword": "password",
    "userUserId": "00000000-0000-0000-0000-111111111111"
  },
  "apiKeys": [
    {
      "key": "#{apiKey}",
      "description": "Unrestricted dev API key"
    }
  ],
  "requests": [
    {
      "method": "POST",
      "url": "/api/key/generate/#{asymmetricKeyId}",
      "tenantId": "#{defaultTenantId}",
      "body": {
        "key": {
          "algorithm": "RS256",
          "name": "Digital Sous Chef Signing Key",
          "length": 2048
        }
      }
    },
    {
      "method": "PATCH",
      "url": "api/system-configuration",
      "body": {
        "systemConfiguration": {
          "corsConfiguration": {
            "allowCredentials": true,
            "allowedMethods": ["GET", "POST", "PUT", "DELETE", "OPTIONS"],
            "allowedOrigins": [
              "http://localhost:3000",
              "http://localhost:5173",
              "https://localhost:5173",
              "https://localhost:56178"
            ],
            "debug": false,
            "enabled": true,
            "preflightMaxAgeInSeconds": 0
          }
        }
      }
    },
    {
      "method": "PATCH",
      "url": "/api/tenant/#{defaultTenantId}",
      "body": {
        "tenant": {
          "issuer": "http://localhost:9011"
        }
      }
    },
    {
      "method": "POST",
      "url": "/api/application/#{applicationId}",
      "tenantId": "#{defaultTenantId}",
      "body": {
        "application": {
          "name": "Digital Sous Chef",
          "oauthConfiguration": {
            "authorizedRedirectURLs": [
              "http://localhost:3000",
              "http://localhost:5173",
              "https://localhost:5173",
              "https://localhost:56178",
              "https://localhost:56178/app/callback"
            ],
            "authorizedOriginURLs": [
              "http://localhost:3000",
              "http://localhost:5173",
              "https://localhost:5173",
              "https://localhost:56178"
            ],
            "clientSecret": "super-secret-secret-that-should-be-regenerated-for-production",
            "logoutURL": "https://localhost:56178",
            "enabledGrants": ["authorization_code", "refresh_token"],
            "clientAuthenticationPolicy": "NotRequiredWhenUsingPKCE",
            "proofKeyForCodeExchangePolicy": "Required",
            "generateRefreshTokens": true,
            "requireRegistration": true
          },
          "jwtConfiguration": {
            "enabled": true,
            "accessTokenKeyId": "#{asymmetricKeyId}",
            "idTokenKeyId": "#{asymmetricKeyId}"
          }
        }
      }
    },
    {
      "method": "POST",
      "url": "/api/user/registration",
      "body": {
        "user": {
          "email": "#{adminEmail}",
          "password": "#{adminPassword}",
          "firstName": "Admin",
          "lastName": "User"
        },
        "registration": {
          "applicationId": "#{FUSIONAUTH_APPLICATION_ID}",
          "roles": ["admin"]
        }
      }
    },
    {
      "method": "POST",
      "url": "/api/user/registration/#{userUserId}",
      "body": {
        "user": {
          "email": "#{userEmail}",
          "firstName": "Chef",
          "lastName": "Example",
          "password": "#{userPassword}"
        },
        "registration": {
          "applicationId": "#{applicationId}"
        }
      }
    }
  ]
}
